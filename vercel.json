{
    "version": 2,
    "outputDirectory": "public",
    "buildCommand": "npm run build",
    "framework": null,
    "installCommand": "npm install && composer install --no-dev --optimize-autoloader",
    "routes": [
        {
            "src": "/(css|js|build|fonts)/(.+)",
            "dest": "/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ],
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false"
    }
}
